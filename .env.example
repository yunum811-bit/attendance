# ============================================
# Environment Variables — Attendance System
# ============================================
# คัดลอกไฟล์นี้เป็น .env แล้วเปลี่ยนค่าตามต้องการ
# cp .env.example .env

# API Key สำหรับ External API (CRM integration)
# สร้าง key ใหม่ด้วย: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ต้องตั้งค่านี้เพื่อเปิดใช้ /api/external endpoints
API_KEY=your-secret-api-key-here

# Server port (default: 4000)
PORT=4000
